# pipeline runtime artifacts — ship only the two runtime JSON shapes the app
# reads (index.json + each creator's dataset.json, bundled via import.meta.glob);
# keep raw media/transcripts/frames/cookies out of git.
data/creators/*
!data/creators/index.json
!data/creators/*/
data/creators/*/*
!data/creators/*/dataset.json
!data/creators/*/post-dates.json
!data/creators/*/extract-done.json
# Yahoo quoteType + name cache (symbol-scope.ts). Regenerable + static per symbol,
# so a local/VM cache, never committed.
data/symbol-meta.json
data/symbol-types.json
# Old loose-JSON price store (replaced by data/prices.db SQLite).
data/prices/
.chrome-profile
playwright-report
test-results
perf/.report

# og image previews (local)
.og-preview/

# build-time precompute (scripts/prebuild.ts) — regenerated on every build
public/og/
public/og.png
public/datasets/
public/prices/
public/avatars/
public/llms.txt
public/calls-index.json

# bake-off generated reports
bakeoff-glm5p2-*.md

# throwaway one-off IG probe (uses local session cookie jars, like cookies.txt)
scripts/probe-ig.ts

