GROQ_API_KEY=gsk_xxx
# X/Twitter scrape (pipeline:x) — base64 cookie key from a THROWAWAY account, never your main
RETTIWT_API_KEY=
# Fireworks (gpt-oss-120b) — text classification for the high-volume X path
FIREWORKS_API_KEY=
# PostHog analytics (client-side; project token is public). Build-time VITE_ var —
# set in Vercel too. Omit the key to disable analytics (local dev). Events ride a
# reverse proxy at /relay (nitro routeRules in vite.config.ts), so there's no host
# var — the US upstreams are baked into those rules (swap them for the EU region).
VITE_POSTHOG_KEY=
# Neon Postgres (Vercel Marketplace, "influencer-tracker-db"). DATABASE_URL = pooled owner
# connection — used by db:migrate and db:roles (the privileged owner DDL).
DATABASE_URL=
# Direct (non-pooled) connection — used for DDL/migrations if the pooler misbehaves.
DATABASE_URL_UNPOOLED=
# Least-privilege role connection strings (build with `bun run db:roles` after migrate).
# Public SSR read path (getDb) — SELECT-only "serve" role. Falls back to DATABASE_URL if unset.
DATABASE_URL_SERVE=
# Operator writers (db:backfill, db:materialize) — "ingest" role. Falls back to DATABASE_URL if unset.
DATABASE_URL_INGEST=
# A separate Neon BRANCH — golden-master + immutability tests run here (they TRUNCATE,
# so this must NOT point at the main branch; an interlock refuses if it equals DATABASE_URL).
# DB tests skip when unset.
DATABASE_URL_TEST=
# Ingest-role creds at the test-branch host — the prices-immutability test connects here.
DATABASE_URL_INGEST_TEST=
# Serve-role creds at the test-branch host — the serve-readonly test connects here. Skips when unset.
DATABASE_URL_SERVE_TEST=
# Role passwords (>=16 chars [A-Za-z0-9_-]); used by scripts/apply-roles.ts.
INGEST_ROLE_PASSWORD=
SERVE_ROLE_PASSWORD=
# Read path: "1" = serve from DB (SSR only), unset/"0" = static JSON. Static is the fallback.
USE_DB=0
# Shared secret guarding the POST /api/revalidate purge seam (Plan 3b ingest→CDN bust).
# >=32 random chars (openssl rand -base64 32). Guards the Plan 3b ingest->purge seam; no
# endpoint rate limit yet, so entropy is the brute-force defense. Unset => 503 (never an open purge).
REVALIDATE_TOKEN=
