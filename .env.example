GROQ_API_KEY=gsk_xxx
# X/Twitter scrape (pipeline:x) — base64 cookie key from a THROWAWAY account, never your main
RETTIWT_API_KEY=
# Fireworks (gpt-oss-120b) — text classification for the high-volume X path
FIREWORKS_API_KEY=
# PostHog analytics (client-side; project token is public). Build-time VITE_ vars —
# set in Vercel too. Omit the key to disable analytics (local dev). Host: US default,
# use https://eu.i.posthog.com for the EU region.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
