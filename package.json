    "@tanstack/router-plugin": "^1.168.19",
    "@visx/curve": "4.0.0",
    "@visx/event": "4.0.0",
    "@visx/grid": "4.0.0",
    "@visx/group": "4.0.0",
    "@visx/pattern": "4.0.0",
    "@visx/responsive": "4.0.0",
    "@visx/scale": "4.0.0",
    "@visx/shape": "4.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-array": "^3.2.4",
    "d3-shape": "^3.2.0",
